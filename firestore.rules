rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Admin password check (requires authentication, but anyone authenticated can read it)
    match /admin/password {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Admin settings
    match /admin/settings {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // System settings
    match /system_settings/config {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Student sessions
    match /student_sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Exams bank
    match /exams_bank/{examId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Questions
    match /questions/{questionId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Results
    match /results/{resultId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Exam Progress
    match /exam_progress/{progressId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Announcements
    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Announcement Comments
    match /announcement_comments/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Theories
    match /theories/{theoryId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
